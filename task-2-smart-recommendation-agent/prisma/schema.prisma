generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id                     String @id @default(uuid())
  user_id                String @unique
  rating_count           Int
  avg_rating             Float
  avg_rating_text_length Float
  persona_summary        String
}

model review {
  id                String   @id @default(uuid())
  user_id           String
  asin              String
  rating            Float
  review_text       String
  review_title      String
  verified_purchase Boolean
  reviewed_at       DateTime
}
